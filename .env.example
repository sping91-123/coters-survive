NEXT_PUBLIC_SITE_URL=https://your-domain.kr

# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Optional. If set, Pro 결제 버튼이 해당 결제 링크로 이동합니다.
# TossPayments 결제 링크, 결제위젯을 붙인 별도 주문서, PortOne 링크 등을 넣을 수 있습니다.
NEXT_PUBLIC_PRO_PAYMENT_URL=
NEXT_PUBLIC_PRO_MONTHLY_PAYMENT_URL=
NEXT_PUBLIC_PRO_YEARLY_PAYMENT_URL=

# Optional. TossPayments 결제위젯을 직접 붙일 때 사용할 키입니다.
# 실제 결제 승인에는 서버 전용 시크릿 키가 필요하므로 브라우저에 노출하지 마세요.
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=

# Optional. AI commentary API route may use this when the backend integration is enabled.
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# Optional. Capacitor 앱스토어 래퍼가 열 배포 웹앱 주소입니다.
CAPACITOR_SERVER_URL=https://your-domain.kr
