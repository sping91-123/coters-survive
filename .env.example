NEXT_PUBLIC_SITE_URL=https://your-domain.kr

# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Optional. If set, PRO 신청 완료 화면에 결제 버튼이 표시됩니다.
# TossPayments / PortOne / SmartStore / 기타 결제 링크를 넣을 수 있습니다.
NEXT_PUBLIC_PRO_PAYMENT_URL=

# Optional. AI commentary API route may use this when the backend integration is enabled.
OPENAI_API_KEY=
