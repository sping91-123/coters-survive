//@version=6
indicator("Coters [v2.42] ", overlay=true, max_lines_count=500, max_bars_back=2000, max_boxes_count=500, max_labels_count=500)

// =============================================================================
// [PART 0] GLOBAL DEFINITIONS (TYPES & METHODS & FUNCTIONS)
// =============================================================================

// -----------------------------------------------------------------------------
// [0-1] FVG Definitions
// -----------------------------------------------------------------------------
type fvg
    float max
    float min
    bool isbull
    int t = time
    string timeframe
    bool is_ifvg = false

f_detect_optimized(float thresholdPer, bool auto) =>
    cumVal = ta.cum((high - low) / low)
    threshold = auto ? cumVal / math.max(bar_index, 1) : thresholdPer / 100
    bull_fvg = low > high[2] and close[1] > high[2] and (low - high[2]) / high[2] > threshold
    bear_fvg = high < low[2] and close[1] < low[2] and (low[2] - high) / high > threshold

    float res_max = na
    float res_min = na
    int res_time = na

    if bull_fvg
        res_max := low
        res_min := high[2]
        res_time := time
    else if bear_fvg
        res_max := low[2]
        res_min := high
        res_time := time

    [bull_fvg, bear_fvg, res_max, res_min, res_time]

// -----------------------------------------------------------------------------
// [0-2] Sweep (Liquidity) Definitions
// -----------------------------------------------------------------------------
type piv
    float prc
    int   bix
    bool  brk
    bool  mit
    bool  tak
    bool  wic
    line  lin

type boxBr
    box  bx
    line ln
    bool br
    int  dr

method isSet(float piv) => bool out = not na(piv)
method p(piv piv, float val) => float out = (100 / piv.prc * val) - 100

method l(piv get, color c, string s='sd') =>
    style = switch s
        'dt' => line.style_dotted
        'ds' => line.style_dashed
        =>      line.style_solid
    get.lin := line.new(get.bix, get.prc, bar_index, get.prc, color=c, style=style)

method br(piv get, color c3, color c, int d) =>
    y1 = d == 1 ? high : get.prc
    y2 = d == 1 ? get.prc : low
    boxBr.new(
      box.new(bar_index -1, y1, bar_index +1, y2
      , border_color = na
      , bgcolor=c3)
      , line.new(bar_index , y1, bar_index, y2, color=c, width=3)
      , false
      , d)

var line[] _lnDotArr = array.new_line(0)
lnDot(y, c) =>
    ln = line.new(bar_index, y, bar_index+3, y, color=c, style=line.style_dotted)
    array.push(_lnDotArr, ln)
    if array.size(_lnDotArr) > 30
        line.delete(array.shift(_lnDotArr))
    ln

// -----------------------------------------------------------------------------
// [0-3] POC & Value Area Calculation Function
// -----------------------------------------------------------------------------
f_get_vp_data(int lookback_len, int num_bars) =>
    float result_poc = na
    float result_vah = na
    float result_val = na
    if barstate.islast
        float highest_p = high[0]
        float lowest_p  = low[0]
        int loops = math.min(lookback_len, bar_index)
        if loops > 0
            for i = 0 to loops - 1
                highest_p := math.max(highest_p, high[i])
                lowest_p  := math.min(lowest_p, low[i])
            float interval = math.max((highest_p - lowest_p) / math.max(num_bars - 1, 1), 1e-10)
            a_vols = array.new_float(num_bars, 0.0)

            for i = 0 to loops - 1
                float h = high[i]
                float l = low[i]
                float v = volume[i]
                if not na(v)
                    int start_idx = int((l - lowest_p) / interval)
                    int end_idx   = int((h - lowest_p) / interval)
                    start_idx := math.max(0, start_idx)
                    end_idx   := math.min(num_bars - 1, end_idx)
                    if start_idx <= end_idx
                        float vol_per_bin = v / (end_idx - start_idx + 1)
                        for j = start_idx to end_idx
                            array.set(a_vols, j, array.get(a_vols, j) + vol_per_bin)

            float max_v = array.max(a_vols)
            int max_i   = array.indexof(a_vols, max_v)
            result_poc := lowest_p + (max_i * interval)

            float total_vol = array.sum(a_vols)
            float target_vol = total_vol * 0.70
            float current_vol = max_v
            int upper_i = max_i
            int lower_i = max_i

            while current_vol < target_vol and (upper_i < num_bars - 1 or lower_i > 0)
                float vol_up = upper_i < num_bars - 1 ? array.get(a_vols, upper_i + 1) : -1.0
                float vol_dn = lower_i > 0 ? array.get(a_vols, lower_i - 1) : -1.0

                if vol_up >= vol_dn and vol_up >= 0
                    upper_i += 1
                    current_vol += vol_up
                else if vol_dn > vol_up and vol_dn >= 0
                    lower_i -= 1
                    current_vol += vol_dn
                else
                    break

            result_vah := lowest_p + (upper_i * interval)
            result_val := lowest_p + (lower_i * interval)

    [result_poc, result_vah, result_val]

